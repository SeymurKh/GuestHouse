# Зависимости (САМОЕ ВАЖНОЕ, съедает миллионы токенов зря)
node_modules/

# Папки сборки (готовый мусор, который ИИ читать не должен)
.next/
dist/
build/
out/
.nuxt/

# Системные папки
.git/
.vscode/
.idea/

# Кэш
.cache/
.parcel-cache/
.turbo/
*.tsbuildinfo

# Всякие логи ошибок (текст на тысячи строк)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Файлы окружения (скрываем пароли от ИИ + экономим токены)
.env
.env.*
!.env.example

# Файлы блокировок пакетов (иногда весят по 5-10 мегабайт текста, для ревью не нужны)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Тяжелые картинки и статика (если у тебя папки с медиа)
public/images/
public/assets/
public/uploads/
assets/img/