// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Домики гостевого дома
model Room {
  id          String   @id @default(cuid())
  name        String
  description String   // Описание домика
  conditions  String   @default("") // Условия проживания
  advantages  Json     @default("[]") // Преимущества (массив/локализованный объект)
  price       Float
  capacity    Int      // Количество гостей
  amenities   Json     @default("[]") // Удобства (массив/локализованный объект)
  images      Json     @default("[]") // URLs изображений
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Отзывы гостей
model Review {
  id        String   @id @default(cuid())
  guestName String
  rating    Int      // 1-5
  comment   String
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
}

// Настройки сайта
model SiteSettings {
  id          String @id @default(cuid())
  phone       String
  email       String?
  address     String?
  description String?
}
